<?xml version="1.0" encoding="utf-8"?>
<navigation xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:id="@+id/nav_graph"
    app:startDestination="@id/loginFragment">

    <fragment
        android:id="@+id/loginFragment"
        android:name="com.masbek.couponsystem.ui.auth.LoginFragment"
        android:label="Login"
        tools:layout="@layout/fragment_login">
        <action
            android:id="@+id/action_login_to_dashboard"
            app:destination="@id/dashboardFragment"
            app:popUpTo="@id/loginFragment"
            app:popUpToInclusive="true" />
    </fragment>

    <fragment
        android:id="@+id/dashboardFragment"
        android:name="com.masbek.couponsystem.ui.dashboard.DashboardFragment"
        android:label="@string/nav_dashboard"
        tools:layout="@layout/fragment_dashboard">
        <action
            android:id="@+id/action_dashboard_to_projectDetail"
            app:destination="@id/projectDetailFragment" />
    </fragment>

    <fragment
        android:id="@+id/projectsFragment"
        android:name="com.masbek.couponsystem.ui.projects.ProjectsFragment"
        android:label="@string/nav_projects"
        tools:layout="@layout/fragment_projects">
        <action
            android:id="@+id/action_projects_to_createProject"
            app:destination="@id/createProjectFragment" />
        <action
            android:id="@+id/action_projects_to_projectDetail"
            app:destination="@id/projectDetailFragment" />
    </fragment>

    <fragment
        android:id="@+id/createProjectFragment"
        android:name="com.masbek.couponsystem.ui.projects.CreateProjectFragment"
        android:label="@string/create_project_title"
        tools:layout="@layout/fragment_create_project">
        <action
            android:id="@+id/action_createProject_to_projects"
            app:destination="@id/projectsFragment"
            app:popUpTo="@id/projectsFragment"
            app:popUpToInclusive="true" />
    </fragment>

    <fragment
        android:id="@+id/projectDetailFragment"
        android:name="com.masbek.couponsystem.ui.projects.ProjectDetailFragment"
        android:label="Detail Proyek"
        tools:layout="@layout/fragment_project_detail">
        <argument
            android:name="projectId"
            app:argType="integer" />
        <action
            android:id="@+id/action_projectDetail_to_batchReport"
            app:destination="@id/batchReportFragment" />
        <action
            android:id="@+id/action_projectDetail_to_projects"
            app:destination="@id/projectsFragment"
            app:popUpTo="@id/projectsFragment"
            app:popUpToInclusive="true" />
    </fragment>

    <fragment
        android:id="@+id/batchReportFragment"
        android:name="com.masbek.couponsystem.ui.batches.BatchReportFragment"
        android:label="Laporan Batch"
        tools:layout="@layout/fragment_batch_report">
        <argument
            android:name="batchId"
            app:argType="integer" />
        <argument
            android:name="batchNumber"
            app:argType="integer"
            android:defaultValue="0" />
        <argument
            android:name="projectName"
            app:argType="string"
            android:defaultValue="" />
    </fragment>

    <fragment
        android:id="@+id/settingsFragment"
        android:name="com.masbek.couponsystem.ui.settings.SettingsFragment"
        android:label="@string/nav_settings"
        tools:layout="@layout/fragment_settings">
        <action
            android:id="@+id/action_settings_to_login"
            app:destination="@id/loginFragment"
            app:popUpTo="@id/nav_graph"
            app:popUpToInclusive="true" />
    </fragment>

</navigation>
